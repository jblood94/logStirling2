install.packages("remotes")
remotes::install_github("jblood94/logStirling2")
reprex::reprex({
library(logStirling2)
# A slice of the Stirling triangle as a matrix
logStirling2(n = 5:8, k = 2:5, as.matrix = TRUE)
# All non-trivial k for multiple n, as a vector
logStirling2(n = 3:10, k = NULL, as.matrix = FALSE, ones = FALSE)
# Full row for large n
options(digits = 16)
s <- logStirling2(n = 38e3, k = NULL, as.matrix = FALSE, ones = FALSE)
length(s)
s[10:15]
exp(sapply(10:15, \(k) stirling2direct(38e3, k)))
# Temme approximation — fast even for very large n
s <- logStirling2Temme(n = 1e5)
s[1000:1005]
exp(sapply(1000:1005, \(k) stirling2direct(1e5, k)))
# Exact big-integer result for a scalar pair
stirling2direct(300, 30)
})
library(logStirling2)
# A slice of the Stirling triangle as a matrix
logStirling2(n = 5:8, k = 2:5, as.matrix = TRUE)
# All non-trivial k for multiple n, as a vector
logStirling2(n = 8:10, k = NULL, as.matrix = FALSE, ones = FALSE)
# Full row for large n
options(digits = 16)
s <- logStirling2(n = 38e3, k = NULL, as.matrix = FALSE, ones = FALSE)
length(s)
s[10:15]
log(sapply(10:15, \(k) stirling2direct(38e3, k)))
s[10:13]
sapply(10:15, \(k) log(stirling2direct(38e3, k)))
s <- logStirling2(n = 38e3, k = NULL, as.matrix = FALSE)
length(s)
s[10:13]
sapply(10:15, \(k) log(stirling2direct(38e3, k)))
# Temme approximation — fast even for very large n
s <- logStirling2Temme(n = 1e5)
s[1000:1003]
sapply(10:13, \(k) log(stirling2direct(38e3, k)))
sapply(10:13, \(k) log(stirling2direct(1e5, k)))
s[1000:1003]
sapply(1000:1003, \(k) log(stirling2direct(1e5, k)))
