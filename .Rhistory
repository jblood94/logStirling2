# Group n by cache blocks (0-999, 1000-1999, etc.)
nu <- sort(unique(n))
if (nu[length(nu)] < 3) {
if (is.null(k)) k <- 1:nu[length(nu)]
S <- lapply(n, \(i) numeric(i)[k])
if (as.matrix) {
S <- `dimnames<-`(do.call(rbind, S), list(n, k))
} else {
S <- unlist(S)
S <- S[!is.na(S)]
}
return(S)
}
if (length(i <- which(nu < 3))) {
nu0 <- nu[i]
nu <- nu[-i]
ones <- TRUE
} else nu0 <- vector(mode(nu), 0)
blocks <- split(nu, nu%/%1e3)
states <- if (nu[length(nu)] > 999) c(list(NULL), logS_states) else list(NULL)
bu <- pmin(as.integer(names(blocks)) + 1, length(states))
sb <- states[bu]
ni <- match(n, c(nu0, nu))
# Set up execution wrapper
fapply <- if (parallel && requireNamespace("future.apply", quietly = TRUE)) {
print("parallel"); \(...) future.apply::future_lapply(..., future.seed = TRUE)
} else base::lapply
# Process blocks
S <- unlist(fapply(1:length(blocks), function(i) {
if (length(blocks[[i]]) == 1) { # single row
logStirling2Row_C(blocks[[i]], state = sb[[i]])
} else if (blocks[[i]][1] == (bu[i] - 1)*1e3 + (bu[i] == 1)*3 &&
all(diff(blocks[[i]]) == 1)) { # all rows
logStirling2All_C(blocks[[i]][length(blocks[[i]])], state = sb[[i]])
} else logStirling2Mult_C(blocks[[i]], state = sb[[i]])
}), FALSE, FALSE)
S <- unname(split(S, rep.int(nu, nu - 2)))
if (is.null(k)) {
if (!as.matrix && !ones) return(unlist(S[ni])) else k <- 1:nu[length(nu)]
}
S <- c(lapply(nu0, \(i) numeric(i)[k]), lapply(S, \(s) c(0, s, 0)[k]))[ni]
if (as.matrix) {
`dimnames<-`(do.call(rbind, S), list(c(nu0, nu)[ni], k))
} else unlist(lapply(S, \(s) s[!is.na(s)]), FALSE, FALSE)
}
# This should now be warning-free
res_seq <- logStirling2(n_test, parallel = FALSE)
res_par <- logStirling2(n_test, parallel = TRUE)
future::plan(future::multisession, workers = 2)
# Initialize workers
future::value(future::future(library(logStirling2), seed = TRUE))
on.exit(future::plan(future::sequential))
res_par <- logStirling2(n_test, parallel = TRUE)
devtools::install()
library(logStirling2)
library(future)
plan(multisession, workers = 2)
res_par <- logStirling2(c(50, 1050), parallel = TRUE)
n_test <- seq(1500, 5500, by = 1000)
system.time(res_seq(logStirling2(n_test)))
system.time(res_seq <- logStirling2(n_test))
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
n_test <- seq(1500, 20500, by = 1000)
system.time(res_seq <- logStirling2(n_test))
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
future::plan(future::multisession, workers = 15)
# Initialize workers
future::value(future::future(library(logStirling2), seed = TRUE))
system.time(res_seq <- logStirling2(n_test))
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
n_test <- 3:15e3
system.time(res_seq <- logStirling2(n_test))
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
future::plan(future::sequential)
future::plan(future::multisession, workers = 15)
system.time(res_par <- logStirling2(n_test, parallel = TRUE))
future::plan(future::sequential)
logStirling2par <- function(n, k = NULL, as.matrix = TRUE, ones = TRUE,
cl = NULL) {
# check inputs
if (length(i <- which(n < 1))) {
n <- n[-i]
stopifnot("All n are less than 1." = length(n) > 0)
warning("n < 1 dropped.")
}
if (any(n%%1 != 0)) {
warning("n coerced to natural numbers.")
n <- floor(n)
}
if (!is.null(k)) {
if (length(i <- which(k < 1))) {
k <- k[-i]
stopifnot("All k are less than 1." = length(k) > 0)
warning("k < 1 dropped.")
}
if (any(k%%1 != 0)) {
warning("k coerced to natural numbers.")
k <- floor(k)
}
if (length(n) == 1 && length(k) == 1) { # use `stirling2direct`
S <- log(stirling2direct(n, k))
return(if (as.matrix) matrix(S, 1, 1, 0, list(n, k)) else S)
}
}
# Group n by cache blocks (0-999, 1000-1999, etc.)
nu <- sort(unique(n))
if (nu[length(nu)] < 3) {
if (is.null(k)) k <- 1:nu[length(nu)]
S <- lapply(n, \(i) numeric(i)[k])
if (as.matrix) {
S <- `dimnames<-`(do.call(rbind, S), list(n, k))
} else {
S <- unlist(S)
S <- S[!is.na(S)]
}
return(S)
}
if (length(i <- which(nu < 3))) {
nu0 <- nu[i]
nu <- nu[-i]
ones <- TRUE
} else nu0 <- vector(mode(nu), 0)
blocks <- split(nu, nu%/%1e3)
states <- if (nu[length(nu)] > 999) c(list(NULL), logS_states) else list(NULL)
bu <- pmin(as.integer(names(blocks)) + 1, length(states))
sb <- states[bu]
ni <- match(n, c(nu0, nu))
# Set up execution wrapper
if (length(blocks) > 1) {
if (is.null(cl)) {
cl <- parallel::makeCluster(min(parallel::detectCores() - 1,
length(blocks)))
invisible(parallel::clusterEvalQ(cl, library("logStirling2")))
fapply <- \(...) parallel::parLapply(cl, ...)
on.exit(parallel::stopCluster(cl))
}
} else fapply <- base::lapply
# Process blocks
S <- unlist(fapply(1:length(blocks), function(i) {
if (length(blocks[[i]]) == 1) { # single row
logStirling2Row_C(blocks[[i]], state = sb[[i]])
} else if (blocks[[i]][1] == (bu[i] - 1)*1e3 + (bu[i] == 1)*3 &&
all(diff(blocks[[i]]) == 1)) { # all rows
logStirling2All_C(blocks[[i]][length(blocks[[i]])], state = sb[[i]])
} else logStirling2Mult_C(blocks[[i]], state = sb[[i]])
}), FALSE, FALSE)
S <- unname(split(S, rep.int(nu, nu - 2)))
if (is.null(k)) {
if (!as.matrix && !ones) return(unlist(S[ni])) else k <- 1:nu[length(nu)]
}
S <- c(lapply(nu0, \(i) numeric(i)[k]), lapply(S, \(s) c(0, s, 0)[k]))[ni]
if (as.matrix) {
`dimnames<-`(do.call(rbind, S), list(c(nu0, nu)[ni], k))
} else unlist(lapply(S, \(s) s[!is.na(s)]), FALSE, FALSE)
}
